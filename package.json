{
  "name": "ocor-cli",
  "version": "1.0.0",
  "description": "Powerful multi-agent orchestrator for OpenCode — 12+ specialized AI agents that work together",
  "main": "dist/index.js",
  "bin": {
    "opencode-orchestrator": "dist/cli/index.js",
    "ocor": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "install-global": "npm run build && npm install -g ."
  },
  "keywords": [
    "opencode",
    "orchestrator",
    "multi-agent",
    "ai",
    "coding-agent",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "glob": "^10.3.0",
    "ink": "^5.0.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.0",
    "react": "^18.3.0",
    "tree-sitter": "^0.21.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "files": [
    "dist",
    "scripts",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thedileepkumar-dk/Opencode-Orchestrator"
  }
}
